{
  "$schema": "/etc/xdg/swaync/configSchema.json",

  "ignore-gtk-theme": true,
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "layer-shell": true,
  "cssPriority": "user",

  "timeout": 5,
  "timeout-low": 3,
  "timeout-critical": 0,
  "fit-to-screen": true,
  "relative-timestamps": true,
  "notification-grouping": true,
  "hide-on-action": true,
  "hide-on-clear": false,
  "text-empty": "Нет уведомлений",

  "control-center-margin-top": 8,
  "control-center-margin-bottom": 0,
  "control-center-margin-right": 8,
  "control-center-margin-left": 0,
  "control-center-width": 370,
  "control-center-height": -1,
  "notification-window-width": 360,

  "image-visibility": "when-available",
  "notification-body-image-height": 100,
  "notification-body-image-width": 200,
  "notification-2fa-action": true,
  "notification-inline-replies": false,

  "widgets": [
    "title",
    "dnd",
    "volume",
    "backlight",
    "mpris",
    "notifications",
    "buttons-grid"
  ],

  "widget-config": {
    "title": {
      "text": "Уведомления",
      "clear-all-button": true,
      "button-text": "Очистить"
    },
    "dnd": {
      "text": "Не беспокоить"
    },
    "volume": {
      "label": "󰕾",
      "show-per-app": false
    },
    "backlight": {
      "label": "󰃠"
    },
    "mpris": {
      "autohide": true,
      "show-album-art": "always",
      "loop-carousel": false
    },
    "notifications": {
      "vexpand": true
    },
    "buttons-grid": {
      "buttons-per-row": 4,
      "actions": [
        {
          "label": "󰖩",
          "tooltip": "Wi-Fi",
          "type": "toggle",
          "active": true,
          "command": "sh -c '[[ $SWAYNC_TOGGLE_STATE == true ]] && nmcli radio wifi on || nmcli radio wifi off'",
          "update-command": "sh -c '[[ $(nmcli radio wifi) == \"enabled\" ]] && echo true || echo false'"
        },
        {
          "label": "󰂯",
          "tooltip": "Bluetooth",
          "type": "toggle",
          "active": false,
          "command": "sh -c '[[ $SWAYNC_TOGGLE_STATE == true ]] && bluetoothctl power on || bluetoothctl power off'",
          "update-command": "bluetoothctl show | grep -q 'Powered: yes' && echo true || echo false"
        },
        {
          "label": "󰹑",
          "tooltip": "Скриншот",
          "command": "grimblast copy area"
        },
        {
          "label": "󰒲",
          "tooltip": "Сон",
          "command": "systemctl suspend"
        },
        {
          "label": "󰜉",
          "tooltip": "Перезагрузить",
          "command": "systemctl reboot"
        },
        {
          "label": "󰐥",
          "tooltip": "Выключить",
          "command": "systemctl poweroff"
        },
        {
          "label": "󰍃",
          "tooltip": "Выйти",
          "command": "hyprctl dispatch exit"
        },
        {
          "label": "󰔄",
          "tooltip": "Перезапустить swaync",
          "command": "pkill swaync && swaync &"
        }
      ]
    }
  },

  "scripts": {
    "log-all": {
      "exec": "~/.config/swaync/scripts/log-notification.sh '$SWAYNC_APP_NAME' '$SWAYNC_SUMMARY' '$SWAYNC_BODY' '$SWAYNC_URGENCY'",
      "run-on": "receive"
    },
    "critical-sound": {
      "exec": "paplay /usr/share/sounds/freedesktop/stereo/bell.oga",
      "urgency": "Critical",
      "run-on": "receive"
    }
  }
}
